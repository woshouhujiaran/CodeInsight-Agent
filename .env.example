# LLM provider: deepseek or openai
LLM_PROVIDER=deepseek

# Model name for the selected provider
LLM_MODEL=deepseek-chat

# Fill your API keys here
DEEPSEEK_API_KEY=

# --- RAG embeddings (retrieval quality) ---
# EMBEDDING_BACKEND: hash | sentence_transformers | openai
# - hash: no extra deps, low quality (demo only)
# - sentence_transformers: local BGE/GTE-class models (recommended offline)
# - openai: OpenAI-compatible /v1/embeddings (set OPENAI_API_KEY)
EMBEDDING_BACKEND=sentence_transformers
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# If using a custom embedding model, set its vector size when needed:
# OPENAI_EMBEDDING_DIM=1536
